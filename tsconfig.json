{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": [
      "bun",
      "node"
    ]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "benchmark/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
